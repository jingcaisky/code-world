# Custom health check message
PING_MESSAGE=pong

# Skip login/signup (local dev / preview only)
# AUTH_DISABLED=true

# ── Code World: Search Configuration ─────────────────────────────────
# Zvec semantic search endpoint (vector DB for code/doc/FAQ retrieval)
# AGENT_NATIVE_ZVEC_ENDPOINT="http://localhost:9090/api/search"
# AGENT_NATIVE_ZVEC_API_KEY=""

# Web search provider: tavily | serpapi | bing
# AGENT_NATIVE_WEB_SEARCH_PROVIDER="tavily"
# AGENT_NATIVE_TAVILY_API_KEY="tvly-..."   # Required for web search
# AGENT_NATIVE_SERPAPI_KEY=""              # Fallback web search

# ── Code World: Triage Configuration ─────────────────────────────────
# Gemini Flash API key for request complexity classification
# AGENT_NATIVE_GEMINI_API_KEY=""           # sk-... or AIza...

# ── Code World: Debug ────────────────────────────────────────────────
# AGENT_NATIVE_DEBUG_CONTEXT="0"           # Set to "1" to log token budgets
